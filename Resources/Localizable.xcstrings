    "These sites will trigger %@.\n`*` matches a subdomain.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستؤدّي هذه المواقع إلى تشغيل %@.\n`*` يطابق نطاقًا فرعيًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Sites lösen %@ aus.\n`*` steht für eine Subdomain."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "These sites will trigger %@.\n`*` matches a subdomain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos sitios activarán %@.\n`*` coincide con un subdominio."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Estos sitios activarán %@.\n`*` coincide con un subdominio."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این سایت‌ها %@ را فعال می‌کنند.\n`*` با یک زیردامنه مطابقت دارد."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces sites déclencheront %@.\n`*` correspond à un sous-domaine."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אתרים אלה יפעילו את %@.\n`*` תואם תת-דומיין."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ये साइटें %@ को ट्रिगर करेंगी।\n`*` किसी सबडोमेन से मेल खाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questi siti attiveranno %@.\n`*` corrisponde a un sottodominio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらのサイトで %@ が動作します。\n`*` はサブドメインに一致します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 사이트에서 %@ 이(가) 실행됩니다.\n`*` 은(는) 하위 도메인과 일치합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze sites activeren %@.\n`*` komt overeen met een subdomein."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Te strony będą uruchamiać %@.\n`*` dopasowuje subdomenę."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estes sites acionarão %@.\n`*` corresponde a um subdomínio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эти сайты будут запускать %@.\n`*` соответствует поддомену."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 将在这些网站中触发。\n`*` 匹配子域名。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 將在這些網站中觸發。\n`*` 比對子網域。"
          }
        }
      }
    },
