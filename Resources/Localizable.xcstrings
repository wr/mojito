            "state": "translated",
            "value": "Tapez `:` pour trouver n'importe quel émoji ou symbole en quelques secondes."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הקלד `:` כדי לחפש כל אימוג'י או סמל בשניות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी इमोजी या प्रतीक को सेकंडों में खोजने के लिए `:` टाइप करें।"
          }
        },
        "it": {
          "stringUnit": {
