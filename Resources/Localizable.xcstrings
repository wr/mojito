    "Anonymous, aggregate counts only — no identifiers. The full dataset is public at [mojito.wells.ee/stats](https://mojito.wells.ee/stats).": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعداد مجهولة ومجمّعة فقط — بلا أي مُعرِّفات. مجموعة البيانات الكاملة علنية على [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur anonyme, aggregierte Zahlen — keine Identifikatoren. Der vollständige Datensatz ist öffentlich unter [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Anonymous, aggregate counts only — no identifiers. The full dataset is public at [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo recuentos anónimos y agregados — sin identificadores. El conjunto de datos completo es público en [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo conteos anónimos y agregados — sin identificadores. El conjunto de datos completo es público en [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "فقط شمارش‌های ناشناس و تجمیعی — بدون هیچ شناسه‌ای. مجموعهٔ کامل داده‌ها در [mojito.wells.ee/stats](https://mojito.wells.ee/stats) عمومی است."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uniquement des compteurs anonymes et agrégés — aucun identifiant. L'ensemble complet des données est public sur [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "רק ספירות אנונימיות ומצרפיות — בלי מזהים. מערך הנתונים המלא פומבי בכתובת [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल गुमनाम, समग्र गणनाएँ — कोई पहचानकर्ता नहीं। पूरा डेटासेट [mojito.wells.ee/stats](https://mojito.wells.ee/stats) पर सार्वजनिक है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo conteggi anonimi e aggregati — nessun identificatore. L'intero set di dati è pubblico su [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "匿名の集計値のみで、識別子はありません。データセット全体は [mojito.wells.ee/stats](https://mojito.wells.ee/stats) で公開されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "익명 집계 수치만 있고 식별자는 없습니다. 전체 데이터셋은 [mojito.wells.ee/stats](https://mojito.wells.ee/stats)에서 공개됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen anonieme, geaggregeerde aantallen — geen identificatiegegevens. De volledige dataset is openbaar op [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tylko anonimowe, zbiorcze liczniki — żadnych identyfikatorów. Pełny zbiór danych jest publiczny na [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas contagens anônimas e agregadas — sem identificadores. O conjunto de dados completo é público em [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только анонимные сводные подсчёты — никаких идентификаторов. Полный набор данных открыт на [mojito.wells.ee/stats](https://mojito.wells.ee/stats)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅匿名的汇总计数——没有任何标识符。完整数据集公开在 [mojito.wells.ee/stats](https://mojito.wells.ee/stats)。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅匿名的彙總計數——沒有任何識別碼。完整資料集公開在 [mojito.wells.ee/stats](https://mojito.wells.ee/stats)。"
          }
        }
      }
    },
