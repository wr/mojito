    "Statistics and GIF searches sent to Giphy are never linked to you, and no personally-identifiable data is stored or sent anywhere.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تُربَط الإحصائيات وعمليات البحث عن GIF المُرسَلة إلى Giphy بك أبدًا، ولا تُخزَّن أو تُرسَل أي بيانات تُعرّف عنك إلى أي مكان."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistiken und an Giphy gesendete GIF-Suchen werden nie mit dir verknüpft, und es werden keine personenbezogenen Daten gespeichert oder irgendwohin gesendet."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistics and GIF searches sent to Giphy are never linked to you, and no personally-identifiable data is stored or sent anywhere."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las estadísticas y las búsquedas de GIF enviadas a Giphy nunca se vinculan contigo, y no se almacena ni se envía a ningún sitio ningún dato que te identifique."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Las estadísticas y las búsquedas de GIF enviadas a Giphy nunca se vinculan contigo, y no se almacena ni se envía a ningún lado ningún dato que te identifique."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "آمار و جست‌وجوهای GIF که به Giphy ارسال می‌شوند هرگز به شما مرتبط نمی‌شوند و هیچ داده‌ای که هویت شما را آشکار کند در جایی ذخیره یا ارسال نمی‌شود."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les statistiques et les recherches de GIF envoyées à Giphy ne sont jamais associées à toi, et aucune donnée permettant de t'identifier n'est stockée ni envoyée où que ce soit."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "סטטיסטיקה וחיפושי GIF שנשלחים ל-Giphy לעולם אינם מקושרים אליך, ושום מידע שמזהה אותך אישית אינו נשמר או נשלח לשום מקום."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आँकड़े और Giphy को भेजी गई GIF खोजें कभी आपसे नहीं जोड़ी जातीं, और कोई व्यक्तिगत पहचान वाला डेटा कहीं संग्रहीत या भेजा नहीं जाता।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le statistiche e le ricerche di GIF inviate a Giphy non vengono mai collegate a te, e nessun dato che possa identificarti viene salvato o inviato da nessuna parte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統計や Giphy に送信される GIF 検索があなたと結び付けられることはなく、個人を特定できるデータがどこかに保存・送信されることもありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "통계와 Giphy로 전송되는 GIF 검색은 절대 당신과 연결되지 않으며, 개인을 식별할 수 있는 데이터는 어디에도 저장되거나 전송되지 않습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistieken en GIF-zoekopdrachten die naar Giphy worden gestuurd, worden nooit aan jou gekoppeld, en er worden nergens persoonlijk identificeerbare gegevens opgeslagen of verzonden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Statystyki i wyszukiwania GIF-ów wysyłane do Giphy nigdy nie są powiązane z tobą, a żadne dane umożliwiające identyfikację nie są nigdzie przechowywane ani wysyłane."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As estatísticas e as buscas de GIF enviadas ao Giphy nunca são vinculadas a você, e nenhum dado que possa identificá-lo é armazenado ou enviado a lugar nenhum."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Статистика и поисковые запросы GIF, отправляемые в Giphy, никогда не связываются с вами, и никакие персональные данные нигде не хранятся и не отправляются."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "统计数据和发送给 Giphy 的 GIF 搜索绝不会与你关联，也不会存储或向任何地方发送任何可识别个人身份的数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "統計資料和傳送給 Giphy 的 GIF 搜尋絕不會與你關聯，也不會儲存或向任何地方傳送任何可識別個人身分的資料。"
          }
        }
      }
    },
