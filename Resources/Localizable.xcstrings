    "`:::` opens the GIF picker regardless of the lists above.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` يفتح منتقي GIF بغضّ النظر عن القوائم أعلاه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` öffnet die GIF-Auswahl unabhängig von den obigen Listen."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` opens the GIF picker regardless of the lists above."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` abre el selector de GIF independientemente de las listas anteriores."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` abre el selector de GIF sin importar las listas anteriores."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` بدون توجه به فهرست‌های بالا، انتخابگر GIF را باز می‌کند."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` ouvre le sélecteur de GIF, quelles que soient les listes ci-dessus."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` פותח את בורר ה-GIF ללא קשר לרשימות שלמעלה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` ऊपर दी गई सूचियों की परवाह किए बिना GIF पिकर खोलता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` apre il selettore di GIF indipendentemente dagli elenchi qui sopra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` を入力すると、上記のリストに関係なく GIF ピッカーが開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` 을(를) 입력하면 위 목록과 관계없이 GIF 선택기가 열립니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` opent de GIF-kiezer ongeacht de bovenstaande lijsten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` otwiera selektor GIF niezależnie od powyższych list."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` abre o seletor de GIF independentemente das listas acima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` открывает выбор GIF независимо от списков выше."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` 会打开 GIF 选择器，无论上述列表如何设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "`:::` 會打開 GIF 選擇器，無論上述清單如何設定。"
          }
        }
      }
    },
