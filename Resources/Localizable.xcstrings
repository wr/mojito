    "Easter eggs still play on screen — these control sound only.": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Easter eggs still play on screen — these control sound only."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Easter Eggs werden weiterhin angezeigt – dies steuert nur den Ton."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los huevos de pascua se siguen viendo en pantalla — esto solo controla el sonido."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Los huevos de pascua se siguen viendo en pantalla — esto solo controla el sonido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les easter eggs s’affichent toujours à l’écran — ceci ne contrôle que le son."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli easter egg vengono comunque mostrati a schermo — questo controlla solo l’audio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os easter eggs continuam aparecendo na tela — isto controla apenas o som."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "イースターエッグは画面上では引き続き再生されます。ここでは音のみを制御します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "彩蛋仍会在屏幕上播放——此处仅控制声音。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "彩蛋仍會在螢幕上播放——此處僅控制聲音。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이스터에그는 화면에 계속 표시됩니다. 여기서는 소리만 제어합니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ईस्टर एग स्क्रीन पर फिर भी चलते रहेंगे — ये केवल ध्वनि नियंत्रित करते हैं।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пасхалки всё равно отображаются на экране — здесь настраивается только звук."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Easter eggs nadal pojawiają się na ekranie — to steruje tylko dźwiękiem."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Easter eggs blijven op het scherm verschijnen — dit regelt alleen het geluid."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تزال البيوض المفاجِئة تظهر على الشاشة — هذا يتحكم في الصوت فقط."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "تخم‌مرغ‌های نوروزی همچنان روی صفحه نمایش داده می‌شوند — این فقط صدا را کنترل می‌کند."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ביצי פסחא עדיין מוצגות על המסך — זה שולט בצליל בלבד."
          }
        }
      }
    },
